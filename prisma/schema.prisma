model User {
  id                               String                  @id
  email                            String                  @unique
  emailVerified                    Boolean                 @default(false)
  name                             String
  password                         String?
  firstName                        String
  lastName                         String
  role                             UserRole                @default(STAFF)
  isActive                         Boolean                 @default(true)
  phone                            String?
  profilePhoto                     String?
  lastLoginAt                      DateTime?               @db.Timestamp(6)
  invitationToken                  String?                 @unique
  invitationExpiresAt              DateTime?               @db.Timestamp(6)
  createdAt                        DateTime                @default(now()) @db.Timestamp(6)
  updatedAt                        DateTime                @updatedAt @db.Timestamp(6)
  accounts                         Account[]
  invitationReviews                CallTimeInvitation[]    @relation("invitation_reviews")
  clients_clients_createdByTousers Client[]                @relation("clients_createdByTousers")
  clients_clients_userIdTousers    Client?                 @relation("clients_userIdTousers")
  communicationLogs                CommunicationLog[]
  contacts                         Contact[]               @relation("contacts_created")
  estimatesCreated                 Estimate[]              @relation("estimates_created")
  eventTemplates                   EventTemplate[]
  events                           Event[]
  invoicesCreated                  Invoice[]               @relation("invoices_created")
  billsCreated                     Bill[]                  @relation("bills_created")
  notification_preferences         NotificationPreference?
  notifications                    Notification[]
  products                         Product[]
  services                         Service[]
  serviceCategories                ServiceCategory[]
  sessions                         Session[]
  staff_staff_createdByTousers     Staff[]                 @relation("staff_createdByTousers")
  staff_staff_userIdTousers        Staff?                  @relation("staff_userIdTousers")
  timeEntriesCreated               TimeEntry[]             @relation("time_entries_created")
  timeEntryRevisionsEdited         TimeEntryRevision[]     @relation("time_entry_revisions_edited_by")

  @@map("users")
}

model Bill {
  id             String        @id @default(uuid()) @db.Uuid
  billNo         String        @unique
  staffId        String        @db.Uuid
  status         BillStatus    @default(DRAFT)
  billDate       DateTime      @db.Date
  dueDate        DateTime?     @db.Date
  terms          String?
  customField1   String?
  customField2   String?
  customField3   String?
  discountType   DiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  depositAmount  Decimal?      @db.Decimal(10, 2)
  shippingAmount Decimal?      @db.Decimal(10, 2)
  salesTaxAmount Decimal?      @db.Decimal(10, 2)
  isTaxable      Boolean       @default(false)
  notes          String?
  paymentDetails String?
  fileLinks      Json?
  isArchived     Boolean       @default(false)
  archivedAt     DateTime?     @db.Timestamp(6)
  createdBy      String
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime      @updatedAt @db.Timestamp(6)
  items          BillItem[]
  staff          Staff         @relation(fields: [staffId], references: [id])
  createdByUser  User          @relation("bills_created", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([billNo])
  @@index([status])
  @@index([createdBy])
  @@map("bills")
}

model BillItem {
  id                  String    @id @default(uuid()) @db.Uuid
  billId              String    @db.Uuid
  date                DateTime? @db.Date
  productId           String?   @db.Uuid
  serviceId           String?   @db.Uuid
  description         String
  quantity            Decimal   @db.Decimal(10, 2)
  price               Decimal   @db.Decimal(10, 2)
  amount              Decimal   @db.Decimal(10, 2)
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime  @updatedAt @db.Timestamp(6)
  actualEnd           DateTime? @db.Timestamp(6)
  actualHours         Decimal?  @db.Decimal(10, 2)
  actualShiftDetails  String?
  actualStart         DateTime? @db.Timestamp(6)
  internalNotes       String?
  scheduleShiftDetail String?
  scheduledEnd        DateTime? @db.Timestamp(6)
  scheduledHours      Decimal?  @db.Decimal(10, 2)
  scheduledStart      DateTime? @db.Timestamp(6)
  bill                Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  product             Product?  @relation(fields: [productId], references: [id])
  service             Service?  @relation(fields: [serviceId], references: [id])

  @@index([billId])
  @@index([productId])
  @@index([serviceId])
  @@map("bill_items")
}

enum BillStatus {
