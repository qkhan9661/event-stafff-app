// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Role Enum
enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  CLIENT
}

// Event Status Enum
enum EventStatus {
  DRAFT
  PUBLISHED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Staff Account Status Enum
enum AccountStatus {
  ACTIVE
  DISABLED
  PENDING
}

// Staff Type Enum
enum StaffType {
  EMPLOYEE
  CONTRACTOR
}

// Availability Status Enum (for staff self-service)
enum AvailabilityStatus {
  OPEN_TO_OFFERS
  BUSY
  TIME_OFF
}

// Skill Level Enum
enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Staff Rating Enum
enum StaffRating {
  NA
  A
  B
  C
}

// Rate Type Enum (for pay/bill rates)
enum RateType {
  PER_HOUR
  PER_SHIFT
  PER_DAY
  PER_EVENT
}

// Call Time Invitation Status Enum
enum CallTimeInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  WAITLISTED
}


// Main User Model (compatible with existing TypeORM schema)
model User {
  id                    String    @id // Better Auth generates its own IDs
  email                 String    @unique // User's email address (must be unique)
  emailVerified         Boolean   @default(false)
  name                  String    // Auto-generated from firstName + lastName (required by Better Auth)
  password              String?   // Optional: Better Auth stores passwords in accounts table
  firstName             String    // User's first name (required, max 50 chars)
  lastName              String    // User's last name (required, max 50 chars)
  role                  UserRole  @default(STAFF) // User's role in the system
  isActive              Boolean   @default(true) // Whether the user account is active
  phone                 String?   // Phone number (optional, validated format)
  profilePhoto          String?   // URL to user's profile photo
  lastLoginAt           DateTime? @db.Timestamp(6) // Last login timestamp

  // Invitation fields (for invitation-based registration)
  invitationToken       String?   @unique // Token for invitation acceptance
  invitationExpiresAt   DateTime? @db.Timestamp(6) // Expiration time for invitation

  createdAt             DateTime  @default(now()) @db.Timestamp(6)
  updatedAt             DateTime  @updatedAt @db.Timestamp(6)

  // Relations
  createdEvents  Event[]    @relation("EventCreator")
  sessions       Session[]
  accounts       Account[]
  client         Client?    @relation("ClientUser")
  createdClients Client[]   @relation("ClientCreator")
  staff          Staff?     @relation("StaffUser")
  createdStaff   Staff[]    @relation("StaffCreator")

  @@map("users")
}

// Event Model
model Event {
  id               String      @id @default(uuid()) @db.Uuid
  eventId          String      @unique // Human-readable ID (EVT-2025-001)
  title            String
  description      String?     @db.Text
  dressCode        String?
  privateComments  String?     @db.Text

  // Venue Information (all required)
  venueName        String
  address          String
  room             String
  city             String
  state            String
  zipCode          String

  // Date and Time (split fields with TBD support)
  startDate        DateTime    @db.Date
  startTime        String?     // "14:30" or "TBD"
  endDate          DateTime    @db.Date
  endTime          String?     // "18:00" or "TBD"
  timezone         String      // IANA timezone (e.g., "America/New_York")

  // Settings
  status           EventStatus @default(DRAFT)

  // File Links (JSON array: [{name: "Contract", link: "https://..."}])
  fileLinks        Json?

  // Creator/Owner
  createdBy        String
  creator          User        @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  // Client Relationship (optional)
  clientId         String?     @db.Uuid
  client           Client?     @relation("EventClient", fields: [clientId], references: [id], onDelete: SetNull)

  // Call Times
  callTimes        CallTime[]  @relation("EventCallTimes")

  // Timestamps
  createdAt        DateTime    @default(now()) @db.Timestamp(6)
  updatedAt        DateTime    @updatedAt @db.Timestamp(6)

  @@index([createdBy])
  @@index([clientId])
  @@index([status])
  @@index([startDate])
  @@index([eventId])
  @@map("events")
}

// Client Model
model Client {
  id              String    @id @default(uuid()) @db.Uuid
  clientId        String    @unique // Human-readable ID (CLT-2025-001)

  // Client Information
  businessName    String
  firstName       String
  lastName        String
  email           String
  cellPhone       String
  businessPhone   String?
  details         String?   @db.Text

  // Primary Address
  venueName       String?
  room            String?
  streetAddress   String
  aptSuiteUnit    String?
  city            String
  country         String
  state           String
  zipCode         String

  // Login Access
  hasLoginAccess  Boolean   @default(false)
  userId          String?   @unique // Nullable - reference to User when login is granted
  user            User?     @relation("ClientUser", fields: [userId], references: [id], onDelete: SetNull)

  // Creator/Owner
  createdBy       String
  creator         User      @relation("ClientCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  // Relations
  events          Event[]   @relation("EventClient")

  // Timestamps
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)

  @@index([createdBy])
  @@index([email])
  @@index([clientId])
  @@map("clients")
}

// Better Auth - Session Model
model Session {
  id        String   @id // Better Auth generates IDs
  userId    String
  expiresAt DateTime @db.Timestamp(6)
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Better Auth - Account Model (for OAuth and credentials)
model Account {
  id           String   @id // Better Auth generates IDs
  userId       String
  accountId    String   // Provider account ID
  providerId   String   // e.g., "google", "email"
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime? @db.Timestamp(6)
  password     String?  // For email/password provider
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// Better Auth - Verification Model (for email verification)
model Verification {
  id         String   @id // Better Auth generates IDs
  identifier String   // Email or other identifier
  value      String   // Verification token
  expiresAt  DateTime @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  @@unique([identifier, value])
  @@map("verifications")
}

// Staff Model
model Staff {
  id                    String             @id @default(uuid()) @db.Uuid
  staffId               String             @unique // Human-readable ID (STF-2025-001)

  // Account Details
  accountStatus         AccountStatus      @default(PENDING)
  staffType             StaffType          @default(EMPLOYEE)

  // Staff Information
  firstName             String             // Max 50 chars
  lastName              String             // Max 50 chars
  phone                 String             @default("") // Validated phone format - set during invitation acceptance
  email                 String             @unique // Validated email
  dateOfBirth           DateTime?          @db.Date // Optional until invitation acceptance

  // Skill Level (displayed as "Experience" in UI)
  skillLevel            SkillLevel         @default(BEGINNER)

  // Availability Status (staff self-service)
  availabilityStatus    AvailabilityStatus @default(OPEN_TO_OFFERS)
  timeOffStart          DateTime?          @db.Date // Start of time off period
  timeOffEnd            DateTime?          @db.Date // End of time off period

  // Address Information (filled during invitation acceptance)
  streetAddress         String             @default("") // Max 300 chars
  aptSuiteUnit          String?            // Optional, max 50 chars
  city                  String             @default("") // Max 100 chars
  country               String             @default("") // Max 100 chars
  state                 String             @default("") // Max 50 chars
  zipCode               String             @default("") // Max 20 chars

  // Custom Admin Fields
  experience            String?            @db.Text // Admin only
  staffRating           StaffRating        @default(NA) // Admin only
  internalNotes         String?            @db.Text // Admin only - not visible to staff

  // Invitation fields
  invitationToken       String?            @unique // Token for invitation acceptance
  invitationExpiresAt   DateTime?          @db.Timestamp(6) // Expiration time for invitation
  hasLoginAccess        Boolean            @default(false) // Whether staff can log in

  // Contractor-Employee Relationship (nullable - employees may not belong to contractor)
  contractorId          String?            @db.Uuid
  contractor            Staff?             @relation("EmployeeToContractor", fields: [contractorId], references: [id], onDelete: SetNull)
  employees             Staff[]            @relation("EmployeeToContractor")

  // User Account Link (for login access)
  userId                String?            @unique
  user                  User?              @relation("StaffUser", fields: [userId], references: [id], onDelete: SetNull)

  // Creator
  createdBy             String
  creator               User               @relation("StaffCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  // Many-to-Many Relations
  positions             StaffPositionAssignment[]

  // Call Time Invitations
  callTimeInvitations   CallTimeInvitation[] @relation("StaffCallTimeInvitations")

  // Timestamps
  createdAt             DateTime           @default(now()) @db.Timestamp(6)
  updatedAt             DateTime           @updatedAt @db.Timestamp(6)

  @@index([createdBy])
  @@index([contractorId])
  @@index([staffId])
  @@index([accountStatus])
  @@index([email])
  @@index([availabilityStatus])
  @@map("staff")
}

// Staff Position Lookup Model
model StaffPosition {
  id          String                    @id @default(uuid()) @db.Uuid
  name        String                    @unique
  description String?
  isActive    Boolean                   @default(true)

  staff       StaffPositionAssignment[]
  callTimes   CallTime[]                @relation("CallTimePosition")

  createdAt   DateTime                  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime                  @updatedAt @db.Timestamp(6)

  @@map("staff_positions")
}


// Staff Position Assignment Junction Table
model StaffPositionAssignment {
  id              String        @id @default(uuid()) @db.Uuid
  staffId         String        @db.Uuid
  positionId      String        @db.Uuid
  
  staff           Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  position        StaffPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  
  assignedAt      DateTime      @default(now()) @db.Timestamp(6)
  
  @@unique([staffId, positionId])
  @@index([staffId])
  @@index([positionId])
  @@map("staff_position_assignments")
}


// Organization Settings Model (for customizable terminology)
model OrganizationSettings {
  id                   String   @id @default(uuid()) @db.Uuid

  // Terminology Customization
  staffTermSingular    String   @default("Staff")
  staffTermPlural      String   @default("Staff")
  eventTermSingular    String   @default("Event")
  eventTermPlural      String   @default("Events")
  roleTermSingular     String   @default("Role")
  roleTermPlural       String   @default("Roles")

  // Future: organizationId for multi-tenancy support

  createdAt            DateTime @default(now()) @db.Timestamp(6)
  updatedAt            DateTime @updatedAt @db.Timestamp(6)

  @@map("organization_settings")
}

// Call Time Model (staffing requirements for events)
model CallTime {
  id                    String        @id @default(uuid()) @db.Uuid
  callTimeId            String        @unique // Human-readable ID (CT-YYYY-NNN)

  // Position Requirement
  positionId            String        @db.Uuid
  position              StaffPosition @relation("CallTimePosition", fields: [positionId], references: [id], onDelete: Restrict)

  // Staffing Requirements
  numberOfStaffRequired Int           @default(1)
  skillLevel            SkillLevel    @default(BEGINNER)

  // Date and Time (may be TBD)
  startDate             DateTime      @db.Date
  startTime             String?       // "14:30" or null for TBD
  endDate               DateTime      @db.Date
  endTime               String?       // "18:00" or null for TBD

  // Pay and Bill Rates
  payRate               Decimal       @db.Decimal(10, 2)
  payRateType           RateType
  billRate              Decimal       @db.Decimal(10, 2)
  billRateType          RateType

  // Notes
  notes                 String?       @db.Text

  // Event Relationship
  eventId               String        @db.Uuid
  event                 Event         @relation("EventCallTimes", fields: [eventId], references: [id], onDelete: Cascade)

  // Invitations
  invitations           CallTimeInvitation[]

  // Timestamps
  createdAt             DateTime      @default(now()) @db.Timestamp(6)
  updatedAt             DateTime      @updatedAt @db.Timestamp(6)

  @@index([eventId])
  @@index([positionId])
  @@index([startDate])
  @@index([callTimeId])
  @@map("call_times")
}

// Call Time Invitation Model (staff assignments to call times)
model CallTimeInvitation {
  id                    String                   @id @default(uuid()) @db.Uuid

  // Call Time Relationship
  callTimeId            String                   @db.Uuid
  callTime              CallTime                 @relation(fields: [callTimeId], references: [id], onDelete: Cascade)

  // Staff Relationship
  staffId               String                   @db.Uuid
  staff                 Staff                    @relation("StaffCallTimeInvitations", fields: [staffId], references: [id], onDelete: Cascade)

  // Invitation Status
  status                CallTimeInvitationStatus @default(PENDING)

  // Response tracking
  respondedAt           DateTime?                @db.Timestamp(6)
  declineReason         String?                  @db.Text

  // Confirmation tracking (for accepted invitations)
  isConfirmed           Boolean                  @default(false) // true if one of the first N to accept
  confirmedAt           DateTime?                @db.Timestamp(6)

  // Timestamps
  createdAt             DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                 @updatedAt @db.Timestamp(6)

  @@unique([callTimeId, staffId])
  @@index([staffId])
  @@index([callTimeId])
  @@index([status])
  @@map("call_time_invitations")
}

