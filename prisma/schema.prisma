generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id
  email                  String                  @unique
  emailVerified          Boolean                 @default(false)
  name                   String
  password               String?
  firstName              String
  lastName               String
  role                   UserRole                @default(STAFF)
  isActive               Boolean                 @default(true)
  phone                  String?
  profilePhoto           String?
  lastLoginAt            DateTime?               @db.Timestamp(6)
  invitationToken        String?                 @unique
  invitationExpiresAt    DateTime?               @db.Timestamp(6)
  createdAt              DateTime                @default(now()) @db.Timestamp(6)
  updatedAt              DateTime                @updatedAt @db.Timestamp(6)
  accounts               Account[]
  createdClients         Client[]                @relation("ClientCreator")
  client                 Client?                 @relation("ClientUser")
  createdEvents          Event[]                 @relation("EventCreator")
  notificationPreference NotificationPreference? @relation("UserNotificationPrefs")
  notifications          Notification[]          @relation("UserNotifications")
  sessions               Session[]
  createdStaff           Staff[]                 @relation("StaffCreator")
  staff                  Staff?                  @relation("StaffUser")

  @@map("users")
}

model Event {
  id              String      @id @default(uuid()) @db.Uuid
  eventId         String      @unique
  title           String
  description     String?
  dressCode       String?
  privateComments String?
  venueName       String
  address         String
  room            String
  city            String
  state           String
  zipCode         String
  startDate       DateTime    @db.Date
  startTime       String?
  endDate         DateTime    @db.Date
  endTime         String?
  timezone        String
  status          EventStatus @default(DRAFT)
  fileLinks       Json?
  createdBy       String
  clientId        String?     @db.Uuid
  createdAt       DateTime    @default(now()) @db.Timestamp(6)
  updatedAt       DateTime    @updatedAt @db.Timestamp(6)
  callTimes       CallTime[]  @relation("EventCallTimes")
  client          Client?     @relation("EventClient", fields: [clientId], references: [id])
  creator         User        @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([clientId])
  @@index([status])
  @@index([startDate])
  @@index([eventId])
  @@map("events")
}

model Client {
  id                  String    @id @default(uuid()) @db.Uuid
  clientId            String    @unique
  businessName        String
  firstName           String
  lastName            String
  email               String
  cellPhone           String
  businessPhone       String?
  details             String?
  venueName           String?
  room                String?
  streetAddress       String
  aptSuiteUnit        String?
  city                String
  country             String
  state               String
  zipCode             String
  hasLoginAccess      Boolean   @default(false)
  userId              String?   @unique
  invitationToken     String?   @unique
  invitationExpiresAt DateTime? @db.Timestamp(6)
  createdBy           String
  createdAt           DateTime  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime  @updatedAt @db.Timestamp(6)
  creator             User      @relation("ClientCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  user                User?     @relation("ClientUser", fields: [userId], references: [id])
  events              Event[]   @relation("EventClient")

  @@index([createdBy])
  @@index([email])
  @@index([clientId])
  @@map("clients")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime @db.Timestamp(6)
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id           String    @id
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime? @db.Timestamp(6)
  password     String?
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  @@unique([identifier, value])
  @@map("verifications")
}

model Staff {
  id                  String                    @id @default(uuid()) @db.Uuid
  staffId             String                    @unique
  accountStatus       AccountStatus             @default(PENDING)
  staffType           StaffType                 @default(EMPLOYEE)
  firstName           String
  lastName            String
  phone               String                    @default("")
  email               String                    @unique
  dateOfBirth         DateTime?                 @db.Date
  skillLevel          SkillLevel                @default(BEGINNER)
  availabilityStatus  AvailabilityStatus        @default(OPEN_TO_OFFERS)
  timeOffStart        DateTime?                 @db.Date
  timeOffEnd          DateTime?                 @db.Date
  streetAddress       String                    @default("")
  aptSuiteUnit        String?
  city                String                    @default("")
  country             String                    @default("")
  state               String                    @default("")
  zipCode             String                    @default("")
  experience          String?
  staffRating         StaffRating               @default(NA)
  internalNotes       String?
  invitationToken     String?                   @unique
  invitationExpiresAt DateTime?                 @db.Timestamp(6)
  hasLoginAccess      Boolean                   @default(false)
  contractorId        String?                   @db.Uuid
  userId              String?                   @unique
  createdBy           String
  createdAt           DateTime                  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime                  @updatedAt @db.Timestamp(6)
  callTimeInvitations CallTimeInvitation[]      @relation("StaffCallTimeInvitations")
  contractor          Staff?                    @relation("EmployeeToContractor", fields: [contractorId], references: [id])
  employees           Staff[]                   @relation("EmployeeToContractor")
  creator             User                      @relation("StaffCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  user                User?                     @relation("StaffUser", fields: [userId], references: [id])
  positions           StaffPositionAssignment[]

  @@index([createdBy])
  @@index([contractorId])
  @@index([staffId])
  @@index([accountStatus])
  @@index([email])
  @@index([availabilityStatus])
  @@map("staff")
}

model StaffPosition {
  id          String                    @id @default(uuid()) @db.Uuid
  name        String                    @unique
  description String?
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime                  @updatedAt @db.Timestamp(6)
  callTimes   CallTime[]                @relation("CallTimePosition")
  staff       StaffPositionAssignment[]

  @@map("staff_positions")
}

model StaffPositionAssignment {
  id         String        @id @default(uuid()) @db.Uuid
  staffId    String        @db.Uuid
  positionId String        @db.Uuid
  assignedAt DateTime      @default(now()) @db.Timestamp(6)
  position   StaffPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  staff      Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, positionId])
  @@index([staffId])
  @@index([positionId])
  @@map("staff_position_assignments")
}

model OrganizationSettings {
  id                String   @id @default(uuid()) @db.Uuid
  staffTermSingular String   @default("Staff")
  staffTermPlural   String   @default("Staff")
  eventTermSingular String   @default("Event")
  eventTermPlural   String   @default("Events")
  roleTermSingular  String   @default("Role")
  roleTermPlural    String   @default("Roles")
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @db.Timestamp(6)

  @@map("organization_settings")
}

model CallTime {
  id                    String               @id @default(uuid()) @db.Uuid
  callTimeId            String               @unique
  positionId            String               @db.Uuid
  numberOfStaffRequired Int                  @default(1)
  skillLevel            SkillLevel           @default(BEGINNER)
  startDate             DateTime             @db.Date
  startTime             String?
  endDate               DateTime             @db.Date
  endTime               String?
  payRate               Decimal              @db.Decimal(10, 2)
  payRateType           RateType
  billRate              Decimal              @db.Decimal(10, 2)
  billRateType          RateType
  notes                 String?
  eventId               String               @db.Uuid
  createdAt             DateTime             @default(now()) @db.Timestamp(6)
  updatedAt             DateTime             @updatedAt @db.Timestamp(6)
  invitations           CallTimeInvitation[]
  event                 Event                @relation("EventCallTimes", fields: [eventId], references: [id], onDelete: Cascade)
  position              StaffPosition        @relation("CallTimePosition", fields: [positionId], references: [id])

  @@index([eventId])
  @@index([positionId])
  @@index([startDate])
  @@index([callTimeId])
  @@map("call_times")
}

model CallTimeInvitation {
  id            String                   @id @default(uuid()) @db.Uuid
  callTimeId    String                   @db.Uuid
  staffId       String                   @db.Uuid
  status        CallTimeInvitationStatus @default(PENDING)
  respondedAt   DateTime?                @db.Timestamp(6)
  declineReason String?
  isConfirmed   Boolean                  @default(false)
  confirmedAt   DateTime?                @db.Timestamp(6)
  createdAt     DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt     DateTime                 @updatedAt @db.Timestamp(6)
  callTime      CallTime                 @relation(fields: [callTimeId], references: [id], onDelete: Cascade)
  staff         Staff                    @relation("StaffCallTimeInvitations", fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([callTimeId, staffId])
  @@index([staffId])
  @@index([callTimeId])
  @@index([status])
  @@map("call_time_invitations")
}

model Notification {
  id                String               @id @default(uuid()) @db.Uuid
  userId            String
  type              NotificationType
  priority          NotificationPriority @default(NORMAL)
  title             String
  message           String
  actionUrl         String?
  actionLabel       String?
  relatedEntityType String?
  relatedEntityId   String?              @db.Uuid
  batchKey          String?
  batchCount        Int                  @default(1)
  isRead            Boolean              @default(false)
  readAt            DateTime?            @db.Timestamp(6)
  isArchived        Boolean              @default(false)
  createdAt         DateTime             @default(now()) @db.Timestamp(6)
  updatedAt         DateTime             @updatedAt @db.Timestamp(6)
  user              User                 @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isArchived])
  @@index([userId, createdAt])
  @@index([batchKey, userId])
  @@map("notifications")
}

model NotificationPreference {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique
  emailEnabled             Boolean  @default(true)
  emailCallTimeInvitations Boolean  @default(true)
  emailEventUpdates        Boolean  @default(true)
  emailShiftReminders      Boolean  @default(true)
  inAppEnabled             Boolean  @default(true)
  createdAt                DateTime @default(now()) @db.Timestamp(6)
  updatedAt                DateTime @updatedAt @db.Timestamp(6)
  user                     User     @relation("UserNotificationPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  CLIENT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccountStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum StaffType {
  EMPLOYEE
  CONTRACTOR
}

enum AvailabilityStatus {
  OPEN_TO_OFFERS
  BUSY
  TIME_OFF
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum StaffRating {
  NA
  A
  B
  C
}

enum RateType {
  PER_HOUR
  PER_SHIFT
  PER_DAY
  PER_EVENT
}

enum CallTimeInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  WAITLISTED
}

enum NotificationType {
  CALL_TIME_INVITATION
  INVITATION_RESPONSE
  INVITATION_CONFIRMED
  WAITLIST_UPDATE
  EVENT_UPDATE
  EVENT_CANCELLED
  SHIFT_REMINDER
  STAFF_INVITATION
  GENERAL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmailTemplateType {
  STAFF_INVITATION
  CLIENT_INVITATION
  CALL_TIME_INVITATION
  CALL_TIME_CONFIRMATION
  CALL_TIME_WAITLISTED
  STAFF_CREDENTIALS
  USER_INVITATION
}

enum SmsTemplateType {
  STAFF_INVITATION
  CLIENT_INVITATION
  CALL_TIME_INVITATION
  CALL_TIME_CONFIRMATION
  CALL_TIME_WAITLISTED
  STAFF_CREDENTIALS
  USER_INVITATION
}

model EmailTemplate {
  id           String            @id @default(uuid()) @db.Uuid
  type         EmailTemplateType @unique
  subject      String
  bodyHtml     String            @db.Text
  isCustomized Boolean           @default(false)
  createdAt    DateTime          @default(now()) @db.Timestamp(6)
  updatedAt    DateTime          @updatedAt @db.Timestamp(6)

  @@map("email_templates")
}

model SmsTemplate {
  id           String          @id @default(uuid()) @db.Uuid
  type         SmsTemplateType @unique
  body         String          @db.Text
  isCustomized Boolean         @default(false)
  createdAt    DateTime        @default(now()) @db.Timestamp(6)
  updatedAt    DateTime        @updatedAt @db.Timestamp(6)

  @@map("sms_templates")
}

model EmailBrandingSettings {
  id                 String   @id @default(uuid()) @db.Uuid
  logoUrl            String?
  primaryColor       String   @default("#667eea")
  secondaryColor     String   @default("#764ba2")
  buttonStyle        String   @default("gradient")
  buttonBorderRadius String   @default("8px")
  fontFamily         String   @default("system-ui")
  headerBackground   String   @default("gradient")
  footerText         String?
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @db.Timestamp(6)

  @@map("email_branding_settings")
}
