generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String    @id
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime? @db.Timestamp(6)
  password     String?
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model CallTimeInvitation {
  id            String                   @id @default(uuid()) @db.Uuid
  callTimeId    String                   @db.Uuid
  staffId       String                   @db.Uuid
  status        CallTimeInvitationStatus @default(PENDING)
  respondedAt   DateTime?                @db.Timestamp(6)
  declineReason String?
  isConfirmed   Boolean                  @default(false)
  confirmedAt   DateTime?                @db.Timestamp(6)
  createdAt     DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt     DateTime                 @updatedAt @db.Timestamp(6)
  callTime      CallTime                 @relation(fields: [callTimeId], references: [id], onDelete: Cascade)
  staff         Staff                    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([callTimeId, staffId])
  @@index([callTimeId])
  @@index([staffId])
  @@index([status])
  @@map("call_time_invitations")
}

model CallTime {
  id                    String                  @id @default(uuid()) @db.Uuid
  callTimeId            String                  @unique
  serviceId             String?                 @db.Uuid
  numberOfStaffRequired Int                     @default(1)
  skillLevel            SkillLevel              @default(BEGINNER)
  startDate             DateTime?               @db.Date
  startTime             String?
  endDate               DateTime?               @db.Date
  endTime               String?
  payRate               Decimal                 @db.Decimal(10, 2)
  payRateType           RateType
  billRate              Decimal                 @db.Decimal(10, 2)
  billRateType          RateType
  notes                 String?
  eventId               String                  @db.Uuid

  // Billing overrides (separate from pay/bill rates for Event Form assignments)
  customCost            Decimal?                @db.Decimal(10, 2)
  customPrice           Decimal?                @db.Decimal(10, 2)

  // Staff requirements
  ratingRequired        StaffRating?
  approveOvertime       Boolean                 @default(false)

  // Billing flag
  commission            Boolean                 @default(false)

  createdAt             DateTime                @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                @updatedAt @db.Timestamp(6)
  invitations           CallTimeInvitation[]
  event                 Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  service               Service?                @relation(fields: [serviceId], references: [id])

  @@index([callTimeId])
  @@index([eventId])
  @@index([serviceId])
  @@index([startDate])
  @@map("call_times")
}

model Client {
  id                             String    @id @default(uuid()) @db.Uuid
  clientId                       String    @unique
  businessName                   String
  firstName                      String
  lastName                       String
  email                          String
  cellPhone                      String
  businessPhone                  String?
  details                        String?
  requirements                   String?

  // Business address (renamed from streetAddress, now optional)
  businessAddress                String?
  city                           String
  state                          String
  zipCode                        String

  // CC Email
  ccEmail                        String?

  // Billing Contact
  billingFirstName               String?
  billingLastName                String?
  billingEmail                   String?
  billingPhone                   String?

  // Login access fields
  hasLoginAccess                 Boolean   @default(false)
  userId                         String?   @unique
  createdBy                      String
  createdAt                      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                      DateTime  @updatedAt @db.Timestamp(6)
  invitationExpiresAt            DateTime? @db.Timestamp(6)
  invitationToken                String?   @unique

  // Relations
  users_clients_createdByTousers User             @relation("clients_createdByTousers", fields: [createdBy], references: [id], onDelete: Cascade)
  users_clients_userIdTousers    User?            @relation("clients_userIdTousers", fields: [userId], references: [id])
  events                         Event[]
  eventTemplates                 EventTemplate[]
  locations                      ClientLocation[]
  invoices                       Invoice[]
  estimates                      Estimate[]

  @@index([clientId])
  @@index([createdBy])
  @@index([email])
  @@map("clients")
}

model ClientLocation {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @db.Uuid

  venueName    String   @db.VarChar(200)
  meetingPoint String?  @db.VarChar(300)
  venueAddress String   @db.VarChar(300)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(50)
  zipCode      String   @db.VarChar(20)

  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)

  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_locations")
}

model EmailBrandingSettings {
  id                 String   @id @default(uuid()) @db.Uuid
  logoUrl            String?
  primaryColor       String   @default("#667eea")
  secondaryColor     String   @default("#764ba2")
  buttonStyle        String   @default("gradient")
  buttonBorderRadius String   @default("8px")
  fontFamily         String   @default("system-ui")
  headerBackground   String   @default("gradient")
  footerText         String?
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @db.Timestamp(6)
  @@map("email_branding_settings")
}

model EmailTemplate {
  id           String            @id @default(uuid()) @db.Uuid
  type         EmailTemplateType @unique
  subject      String
  bodyHtml     String
  isCustomized Boolean           @default(false)
  createdAt    DateTime          @default(now()) @db.Timestamp(6)
  updatedAt    DateTime          @updatedAt @db.Timestamp(6)
  @@map("email_templates")
}

model Event {
  id              String       @id @default(uuid()) @db.Uuid
  eventId         String       @unique
  title           String
  description     String?
  requirements    String?
  privateComments String?
  venueName       String
  address         String
  city            String
  state           String
  zipCode         String
  startDate       DateTime?    @db.Date
  startTime       String?
  endDate         DateTime?    @db.Date
  endTime         String?
  timezone        String
  status          EventStatus  @default(DRAFT)
  fileLinks       Json?
  isArchived      Boolean      @default(false)
  archivedAt      DateTime?    @db.Timestamp(6)

  // Request Information
  requestMethod      RequestMethod?
  requestorName      String?        @db.VarChar(200)
  requestorPhone     String?        @db.VarChar(50)
  requestorEmail     String?        @db.VarChar(255)
  poNumber           String?        @db.VarChar(100)

  // Event Instructions & Documents
  preEventInstructions String?
  eventDocuments       Json?

  // Custom Fields
  customFields         Json?

  // Onsite Contact & Meeting Point
  meetingPoint     String?        @db.VarChar(300)
  onsitePocName    String?        @db.VarChar(200)
  onsitePocPhone   String?        @db.VarChar(50)
  onsitePocEmail   String?        @db.VarChar(255)

  // Billing & Rate Settings
  estimate              Boolean?
  taskRateType          AmountType?
  commission            Boolean?
  commissionAmount      Decimal?     @db.Decimal(10, 2)
  commissionAmountType  AmountType?
  approveForOvertime    Boolean?
  overtimeRate          Decimal?     @db.Decimal(10, 2)
  overtimeRateType      AmountType?

  createdBy       String
  clientId        String?      @db.Uuid
  createdAt       DateTime     @default(now()) @db.Timestamp(6)
  updatedAt       DateTime     @updatedAt @db.Timestamp(6)
  geocodedAt      DateTime?    @db.Timestamp(6)
  latitude        Float?
  longitude       Float?
  callTimes       CallTime[]
  eventProducts   EventProduct[]
  client          Client?      @relation(fields: [clientId], references: [id])
  createdByUser   User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdBy])
  @@index([eventId])
  @@index([startDate])
  @@index([status])
  @@index([isArchived])
  @@map("events")
}

model EventTemplate {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(200)
  description      String?   @db.VarChar(500)

  // Event fields to prefill
  title            String?   @db.VarChar(200)
  eventDescription String?
  requirements     String?   @db.VarChar(200)
  privateComments  String?

  // Venue fields
  venueName        String?   @db.VarChar(200)
  address          String?   @db.VarChar(300)
  city             String?   @db.VarChar(100)
  state            String?   @db.VarChar(50)
  zipCode          String?   @db.VarChar(20)
  latitude         Float?
  longitude        Float?

  // Date & Time fields
  startDate        DateTime? @db.Date
  startTime        String?   @db.VarChar(5)
  endDate          DateTime? @db.Date
  endTime          String?   @db.VarChar(5)
  timezone         String?   @db.VarChar(50)

  // Attachments
  fileLinks        Json?

  // Request Information
  requestMethod      RequestMethod?
  requestorName      String?        @db.VarChar(200)
  requestorPhone     String?        @db.VarChar(50)
  requestorEmail     String?        @db.VarChar(255)
  poNumber           String?        @db.VarChar(100)

  // Event Instructions & Documents
  preEventInstructions String?
  eventDocuments       Json?

  // Custom Fields
  customFields         Json?

  // Onsite Contact & Meeting Point
  meetingPoint     String?        @db.VarChar(300)
  onsitePocName    String?        @db.VarChar(200)
  onsitePocPhone   String?        @db.VarChar(50)
  onsitePocEmail   String?        @db.VarChar(255)

  // Default client (optional)
  clientId         String?   @db.Uuid
  client           Client?   @relation(fields: [clientId], references: [id])

  // Ownership & audit
  createdBy        String
  createdByUser    User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt @db.Timestamp(6)

  @@index([createdBy])
  @@map("event_templates")
}

model Service {
  id                    String                 @id @default(uuid()) @db.Uuid
  serviceId             String                 @unique
  title                 String                 @db.VarChar(200)
  costUnitType          CostUnitType?
  description           String?                @db.VarChar(1000)
  cost                  Decimal?               @db.Decimal(10, 2)
  price                 Decimal?               @db.Decimal(10, 2)
  isActive              Boolean                @default(true)
  createdBy             String
  createdAt             DateTime               @default(now()) @db.Timestamp(6)
  updatedAt             DateTime               @updatedAt @db.Timestamp(6)
  createdByUser         User                   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  callTimes             CallTime[]
  staff                 StaffServiceAssignment[]
  invoiceItems          InvoiceItem[]
  estimateItems         EstimateItem[]

  @@index([serviceId])
  @@index([title])
  @@index([isActive])
  @@map("services")
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  productId       String           @unique
  title           String           @db.VarChar(200)
  description     String?          @db.VarChar(1000)
  priceUnitType   PriceUnitType    @default(UNIT)
  minimumPurchase MinimumPurchase?
  trackInventory  Boolean          @default(false)
  supplier        String?          @db.VarChar(200)
  brand           String?          @db.VarChar(200)
  category        String?          @db.VarChar(200)
  cost            Decimal?         @db.Decimal(10, 2)
  price           Decimal?         @db.Decimal(10, 2)
  isActive        Boolean          @default(true)
  createdBy       String
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @db.Timestamp(6)
  createdByUser   User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  eventProducts   EventProduct[]
  invoiceItems    InvoiceItem[]
  estimateItems   EstimateItem[]

  @@index([productId])
  @@index([title])
  @@index([isActive])
  @@index([category])
  @@map("products")
}

model EventProduct {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @db.Uuid
  productId   String   @db.Uuid
  quantity    Int      @default(1)
  customPrice Decimal? @db.Decimal(10, 2)
  notes       String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([eventId, productId])
  @@index([eventId])
  @@index([productId])
  @@map("event_products")
}

model NotificationPreference {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique
  emailEnabled             Boolean  @default(true)
  emailCallTimeInvitations Boolean  @default(true)
  emailEventUpdates        Boolean  @default(true)
  emailShiftReminders      Boolean  @default(true)
  inAppEnabled             Boolean  @default(true)
  createdAt                DateTime @default(now()) @db.Timestamp(6)
  updatedAt                DateTime @updatedAt @db.Timestamp(6)
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("notification_preferences")
}

model Notification {
  id                String               @id @default(uuid()) @db.Uuid
  userId            String
  type              NotificationType
  priority          NotificationPriority @default(NORMAL)
  title             String
  message           String
  actionUrl         String?
  actionLabel       String?
  relatedEntityType String?
  relatedEntityId   String?              @db.Uuid
  batchKey          String?
  batchCount        Int                  @default(1)
  isRead            Boolean              @default(false)
  readAt            DateTime?            @db.Timestamp(6)
  isArchived        Boolean              @default(false)
  createdAt         DateTime             @default(now()) @db.Timestamp(6)
  updatedAt         DateTime             @updatedAt @db.Timestamp(6)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([batchKey, userId])
  @@index([userId, createdAt])
  @@index([userId, isRead, isArchived])
  @@map("notifications")
}

model OrganizationSettings {
  id                String   @id @default(uuid()) @db.Uuid
  staffTermSingular String   @default("Staff")
  staffTermPlural   String   @default("Staff")
  eventTermSingular String   @default("Event")
  eventTermPlural   String   @default("Events")
  roleTermSingular  String   @default("Role")
  roleTermPlural    String   @default("Roles")
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @db.Timestamp(6)
  globalLabels      Json     @default("{}")
  pageLabels        Json     @default("{}")
  companyAddress    String?
  companyLogoUrl    String?
  companyName       String?
  companyPhone      String?
  companyTagline    String?
  companyWebsite    String?
  companyTimezone   String   @default("UTC")
  @@map("organization_settings")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime @db.Timestamp(6)
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model SmsTemplate {
  id           String          @id @default(uuid()) @db.Uuid
  type         SmsTemplateType @unique
  body         String
  isCustomized Boolean         @default(false)
  createdAt    DateTime        @default(now()) @db.Timestamp(6)
  updatedAt    DateTime        @updatedAt @db.Timestamp(6)
  @@map("sms_templates")
}

model Staff {
  id                           String                       @id @default(uuid()) @db.Uuid
  staffId                      String                       @unique
  accountStatus                AccountStatus                @default(PENDING)
  staffType                    StaffType                    @default(EMPLOYEE)
  staffRole                    StaffRole                    @default(INDIVIDUAL)
  firstName                    String
  lastName                     String
  phone                        String                       @default("")
  email                        String                       @unique
  dateOfBirth                  DateTime?                    @db.Date
  skillLevel                   SkillLevel                   @default(BEGINNER)
  availabilityStatus           AvailabilityStatus           @default(OPEN_TO_OFFERS)
  timeOffStart                 DateTime?                    @db.Date
  timeOffEnd                   DateTime?                    @db.Date
  streetAddress                String                       @default("")
  aptSuiteUnit                 String?
  city                         String                       @default("")
  country                      String                       @default("")
  state                        String                       @default("")
  zipCode                      String                       @default("")
  experience                   String?
  staffRating                  StaffRating                  @default(NA)
  internalNotes                String?
  invitationToken              String?                      @unique
  invitationExpiresAt          DateTime?                    @db.Timestamp(6)
  hasLoginAccess               Boolean                      @default(false)
  companyId                    String?                      @db.Uuid
  userId                       String?                      @unique
  createdBy                    String
  createdAt                    DateTime                     @default(now()) @db.Timestamp(6)
  updatedAt                    DateTime                     @updatedAt @db.Timestamp(6)

  // Custom fields
  customField1                 String?
  customField2                 String?
  customField3                 String?

  // Documents (JSON array of {name, url, type?, size?})
  documents                    Json?

  // Team Details (only when staffRole = TEAM)
  teamEntityName               String?
  teamEmail                    String?
  teamPhone                    String?
  teamAddressLine1             String?
  teamAddressLine2             String?
  teamCity                     String?
  teamState                    String?
  teamZipCode                  String?

  // Relations
  callTimeInvitations          CallTimeInvitation[]
  company                      Staff?                       @relation("staffTostaff", fields: [companyId], references: [id])
  teamMembers                  Staff[]                      @relation("staffTostaff")
  users_staff_createdByTousers User                         @relation("staff_createdByTousers", fields: [createdBy], references: [id], onDelete: Cascade)
  users_staff_userIdTousers    User?                        @relation("staff_userIdTousers", fields: [userId], references: [id])
  services                     StaffServiceAssignment[]
  taxDetails                   StaffTaxDetails?

  @@index([accountStatus])
  @@index([availabilityStatus])
  @@index([companyId])
  @@index([createdBy])
  @@index([email])
  @@index([staffId])
  @@index([staffRole])
  @@map("staff")
}

model StaffServiceAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  staffId    String   @db.Uuid
  serviceId  String   @db.Uuid
  assignedAt DateTime @default(now()) @db.Timestamp(6)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([serviceId])
  @@index([staffId])
  @@map("staff_service_assignments")
}

model StaffTaxDetails {
  id                      String            @id @default(uuid()) @db.Uuid
  staffId                 String            @unique @db.Uuid

  // Tax collection preferences
  collectTaxDetails       Boolean           @default(false)
  trackFor1099            Boolean           @default(false)

  // Business info
  businessStructure       BusinessStructure @default(INDIVIDUAL)
  businessName            String?

  // Tax identifiers (sensitive)
  ssn                     String?
  ein                     String?

  // ID verification documents
  identificationFrontUrl  String?
  identificationBackUrl   String?

  // Electronic consent
  electronic1099Consent   Boolean           @default(false)
  signatureUrl            String?
  consentDate             DateTime?         @db.Timestamp(6)

  // Audit
  createdAt               DateTime          @default(now()) @db.Timestamp(6)
  updatedAt               DateTime          @updatedAt @db.Timestamp(6)

  // Relation
  staff                   Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("staff_tax_details")
}

model User {
  id                               String                    @id
  email                            String                    @unique
  emailVerified                    Boolean                   @default(false)
  name                             String
  password                         String?
  firstName                        String
  lastName                         String
  role                             UserRole                  @default(STAFF)
  isActive                         Boolean                   @default(true)
  phone                            String?
  profilePhoto                     String?
  lastLoginAt                      DateTime?                 @db.Timestamp(6)
  invitationToken                  String?                   @unique
  invitationExpiresAt              DateTime?                 @db.Timestamp(6)
  createdAt                        DateTime                  @default(now()) @db.Timestamp(6)
  updatedAt                        DateTime                  @updatedAt @db.Timestamp(6)
  accounts                         Account[]
  clients_clients_createdByTousers Client[]                  @relation("clients_createdByTousers")
  clients_clients_userIdTousers    Client?                   @relation("clients_userIdTousers")
  events                           Event[]
  eventTemplates                   EventTemplate[]
  notification_preferences         NotificationPreference?
  notifications                    Notification[]
  sessions                         Session[]
  services                         Service[]
  products                         Product[]
  invoicesCreated                  Invoice[]                 @relation("invoices_created")
  estimatesCreated                 Estimate[]                @relation("estimates_created")
  staff_staff_createdByTousers     Staff[]                   @relation("staff_createdByTousers")
  staff_staff_userIdTousers        Staff?                    @relation("staff_userIdTousers")
  @@map("users")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  @@unique([identifier, value])
  @@map("verifications")
}

enum AccountStatus {
  ACTIVE
  DISABLED
  PENDING
  TERMINATED
  ARCHIVED
}

enum AvailabilityStatus {
  OPEN_TO_OFFERS
  BUSY
  TIME_OFF
}

enum CallTimeInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  WAITLISTED
}

enum EmailTemplateType {
  STAFF_INVITATION
  CLIENT_INVITATION
  CALL_TIME_INVITATION
  CALL_TIME_CONFIRMATION
  CALL_TIME_WAITLISTED
  STAFF_CREDENTIALS
  USER_INVITATION
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RequestMethod {
  EMAIL
  TEXT_SMS
  PHONE_CALL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationType {
  CALL_TIME_INVITATION
  INVITATION_RESPONSE
  INVITATION_CONFIRMED
  WAITLIST_UPDATE
  EVENT_UPDATE
  EVENT_CANCELLED
  SHIFT_REMINDER
  STAFF_INVITATION
  GENERAL
}

enum RateType {
  PER_HOUR
  PER_SHIFT
  PER_DAY
  PER_EVENT
}

enum AmountType {
  MULTIPLIER
  FIXED
}

enum CostUnitType {
  HOURLY      // per hour
  ASSIGNMENT  // per assignment (default for service assignments)
  SHIFT       // per shift
  DAY         // per day
  JOB         // per job
}

enum PriceUnitType {
  UNIT
  PACK
  WEIGHT
}

enum ExperienceRequirement {
  ANY
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MinimumPurchase {
  ANY
  ONE
  TWO_TO_FIVE
  SIX_TO_TEN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SmsTemplateType {
  STAFF_INVITATION
  CLIENT_INVITATION
  CALL_TIME_INVITATION
  CALL_TIME_CONFIRMATION
  CALL_TIME_WAITLISTED
  STAFF_CREDENTIALS
  USER_INVITATION
}

enum StaffRating {
  NA
  A
  B
  C
  D
}

enum StaffType {
  EMPLOYEE
  CONTRACTOR
  COMPANY
  FREELANCE
}

enum StaffRole {
  INDIVIDUAL
  TEAM
}

enum BusinessStructure {
  INDIVIDUAL
  LLC
  CORPORATION
  PARTNERSHIP
  OTHER
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  CLIENT
}

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceNo       String        @unique
  clientId        String        @db.Uuid
  status          InvoiceStatus @default(DRAFT)
  invoiceDate     DateTime      @db.Date
  dueDate         DateTime?     @db.Date
  terms           String?
  customField1    String?
  customField2    String?
  customField3    String?
  discountType    DiscountType?
  discountValue   Decimal?      @db.Decimal(10, 2)
  depositAmount   Decimal?      @db.Decimal(10, 2)
  shippingAmount  Decimal?      @db.Decimal(10, 2)
  salesTaxAmount  Decimal?      @db.Decimal(10, 2)
  isTaxable       Boolean       @default(false)
  notes           String?
  paymentDetails  String?
  fileLinks       Json?
  isArchived      Boolean       @default(false)
  archivedAt      DateTime?     @db.Timestamp(6)
  createdBy       String
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @db.Timestamp(6)
  client          Client        @relation(fields: [clientId], references: [id])
  createdByUser   User          @relation("invoices_created", fields: [createdBy], references: [id], onDelete: Cascade)
  items           InvoiceItem[]

  @@index([clientId])
  @@index([invoiceNo])
  @@index([status])
  @@index([createdBy])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  date        DateTime? @db.Date
  productId   String?  @db.Uuid
  serviceId   String?  @db.Uuid
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@index([serviceId])
  @@map("invoice_items")
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
  CONVERTED
}

model Estimate {
  id              String         @id @default(uuid()) @db.Uuid
  estimateNo      String         @unique
  clientId        String         @db.Uuid
  status          EstimateStatus @default(DRAFT)
  estimateDate    DateTime       @db.Date
  expirationDate  DateTime?      @db.Date
  approvedBy      String?
  approvedDate    DateTime?      @db.Date
  terms           String?
  customField1    String?
  customField2    String?
  customField3    String?
  discountType    DiscountType?
  discountValue   Decimal?       @db.Decimal(10, 2)
  depositAmount   Decimal?       @db.Decimal(10, 2)
  shippingAmount  Decimal?       @db.Decimal(10, 2)
  salesTaxAmount  Decimal?       @db.Decimal(10, 2)
  isTaxable       Boolean        @default(false)
  notes           String?
  paymentDetails  String?
  fileLinks       Json?
  isArchived      Boolean        @default(false)
  archivedAt      DateTime?      @db.Timestamp(6)
  createdBy       String
  createdAt       DateTime       @default(now()) @db.Timestamp(6)
  updatedAt       DateTime       @updatedAt @db.Timestamp(6)
  client          Client         @relation(fields: [clientId], references: [id])
  createdByUser   User           @relation("estimates_created", fields: [createdBy], references: [id], onDelete: Cascade)
  items           EstimateItem[]

  @@index([clientId])
  @@index([estimateNo])
  @@index([status])
  @@index([createdBy])
  @@map("estimates")
}

model EstimateItem {
  id          String    @id @default(uuid()) @db.Uuid
  estimateId  String    @db.Uuid
  date        DateTime? @db.Date
  productId   String?   @db.Uuid
  serviceId   String?   @db.Uuid
  description String
  quantity    Decimal   @db.Decimal(10, 2)
  price       Decimal   @db.Decimal(10, 2)
  amount      Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  estimate    Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])
  service     Service?  @relation(fields: [serviceId], references: [id])

  @@index([estimateId])
  @@index([productId])
  @@index([serviceId])
  @@map("estimate_items")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  AMOUNT
  PERCENT
}
